  "tokenColors": [
    {
      "name": "comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6272A4FF"
      }
    },
    {
      "name": "comment.doc",
      "scope": [
        "comment.block.documentation",
        "comment.documentation"
      ],
      "settings": {
        "foreground": "#FF79C6FF"
      }
